{
	"name": "MyOS-C",

	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"VARIANT": "vnc"
		}
	},

	"forwardPorts": [6080],

	"overrideCommand": false,

	"containerEnv": {
		"NOVNC_PORT": "6080",
		"VNC_PORT": "5900",
		"QEMU_OPTS": "-m 512M -serial stdio -vnc :0"
	},

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools"
			]
		}
	}
}
